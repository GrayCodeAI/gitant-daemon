        },
        "yAxis": {
          "axisLabel": "duration",
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s"
        }
      },
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(gitant_http_request_duration_seconds_bucket[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false,
          "format": "heatmap"
        }
      ]
    },
