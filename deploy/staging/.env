# Staging Environment Configuration

# Server
GITANT_PORT=7777
GITANT_HOST=0.0.0.0
GITANT_DATA_DIR=/data

# Logging
GITANT_LOG_LEVEL=info
GITANT_LOG_FORMAT=json

# Database
GITANT_DB_DRIVER=sqlite
GITANT_DB_PATH=/data/gitant.db

# CORS
GITANT_CORS_ORIGINS=https://staging.gitant.io,http://localhost:3303

# P2P
GITANT_ENABLE_P2P=true
GITANT_P2P_LISTEN=/ip4/0.0.0.0/tcp/4001
GITANT_P2P_BOOTSTRAP=/dns4/bootstrap.gitant.io/tcp/4001/p2p/QmBootstrap

# IPFS
GITANT_ENABLE_IPFS=true
GITANT_IPFS_API=/ip4/127.0.0.1/tcp/5001

# Auth
GITANT_ENABLE_AUTH=true
GITANT_SESSION_DURATION=24h

# Rate Limiting
GITANT_RATE_LIMIT=1000
GITANT_RATE_LIMIT_BURST=100

# TLS (handled by ingress)
GITANT_TLS_CERT=
GITANT_TLS_KEY=
